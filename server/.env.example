# Instagram credentials du bot (compte dédié)
IG_BOT_USERNAME=votre_email@gmail.com
IG_BOT_PASSWORD=votre_mot_de_passe

# Session cookie (alternative plus fiable à la connexion automatisée)
# Ouvre instagram.com, F12 > Console > tape: document.cookie
# Copie la valeur de sessionid=... et colle-la ci-dessous
IG_SESSIONID=votre_sessionid_instagram

# Compte à vérifier (celui qu'ils doivent suivre)
IG_TARGET_USERNAME=compte_cible

# TikTok credentials du bot (compte dédié)
TT_BOT_USERNAME=votre_email@gmail.com
TT_BOT_PASSWORD=votre_mot_de_passe

# Compte TikTok à vérifier (celui qu'ils doivent suivre)
TT_TARGET_USERNAME=compte_cible

TT_SESSIONID=votre_sessionid_tiktok

# Port du serveur
PORT=3002
